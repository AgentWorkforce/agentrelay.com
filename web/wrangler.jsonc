{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentrelay-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Production custom domain. Wrangler creates the DNS record + TLS cert as long
  // as the agentrelay.com zone lives in this Cloudflare account.
  "routes": [
    {
      "pattern": "origin-web.agentrelay.com",
      "custom_domain": true
    }
  ],
  // Keep the prod worker off *.workers.dev, but allow per-version preview URLs
  // (used by PR preview deploys via `wrangler versions upload`).
  "workers_dev": false,
  "preview_urls": true,
  "observability": {
    "enabled": true
  }
}
